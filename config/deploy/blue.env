# StoryTime — blue slot (Phase 7A blue/green Option A).
#
# A per-slot environment file. Source it before invoking storytime to run the
# BLUE deployment slot. Contains NO secrets — StoryTime is local-first and
# makes no authenticated calls. Safe to commit.
#
# Usage:
#   scripts/run-slot.sh blue doctor
#   scripts/run-slot.sh blue run --manifest path/to/manifest.json
# or, directly:
#   set -a; . config/deploy/blue.env; set +a; uv run storytime doctor

# Identity. slot scopes the state/feed roots to runs/blue and feed/blue.
STORYTIME_ENVIRONMENT=local
STORYTIME_DEPLOYMENT_SLOT=blue

# State and feed roots are left UNSET on purpose: with the slot set they
# default to runs/blue and feed/blue, which is exactly the separation we want.
# Uncomment to override (and accept that you are no longer slot-separated):
#STORYTIME_RUNS_DIR=runs/blue
#STORYTIME_FEED_DIR=feed/blue

# Telemetry. Opt-in; identical functional behaviour with noop.
STORYTIME_TELEMETRY=noop
STORYTIME_OTLP_ENDPOINT=http://127.0.0.1:4318

# Loopback HTTP serving. Blue and green serve on DIFFERENT ports so both can
# run at once on one host (Architecture Baseline §15: loopback only).
STORYTIME_HTTP_HOST=127.0.0.1
STORYTIME_HTTP_PORT=8000
