# StoryTime — green slot (Phase 7A blue/green Option A).
#
# A per-slot environment file. Source it before invoking storytime to run the
# GREEN deployment slot. Contains NO secrets — StoryTime is local-first and
# makes no authenticated calls. Safe to commit.
#
# Usage:
#   scripts/run-slot.sh green doctor
#   scripts/run-slot.sh green run --manifest path/to/manifest.json
# or, directly:
#   set -a; . config/deploy/green.env; set +a; uv run storytime doctor

# Identity. slot scopes the state/feed roots to runs/green and feed/green.
STORYTIME_ENVIRONMENT=local
STORYTIME_DEPLOYMENT_SLOT=green

# State and feed roots are left UNSET on purpose: with the slot set they
# default to runs/green and feed/green. Uncomment to override:
#STORYTIME_RUNS_DIR=runs/green
#STORYTIME_FEED_DIR=feed/green

# Telemetry. Opt-in; identical functional behaviour with noop.
STORYTIME_TELEMETRY=noop
STORYTIME_OTLP_ENDPOINT=http://127.0.0.1:4318

# Loopback HTTP serving. Green uses a different port from blue so both slots
# can run side by side on one host (Architecture Baseline §15: loopback only).
STORYTIME_HTTP_HOST=127.0.0.1
STORYTIME_HTTP_PORT=8001
