{
  "uid": "storytime-run-timeline",
  "title": "StoryTime \u2014 Run Timeline",
  "description": "Whole-run duration from the pipeline_run_duration_seconds histogram and run-start cadence. The OTLP label pipeline.status is exposed by Prometheus as pipeline_status.",
  "tags": [
    "storytime",
    "phase6a",
    "observability"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "graphTooltip": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "refresh": "10s",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "hide": true,
        "name": "Annotations & Alerts",
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)"
      }
    ]
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Run duration p95 by terminal status",
      "datasource": {
        "type": "prometheus",
        "uid": "storytime-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": true,
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "storytime-prometheus"
          },
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, pipeline_status) (rate(pipeline_run_duration_seconds_bucket[5m])))",
          "legendFormat": "{{pipeline_status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Run starts per second by mode",
      "datasource": {
        "type": "prometheus",
        "uid": "storytime-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": true,
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "storytime-prometheus"
          },
          "refId": "A",
          "expr": "sum by (mode) (rate(pipeline_runs_total[5m]))",
          "legendFormat": "{{mode}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Completed-run cadence by status",
      "datasource": {
        "type": "prometheus",
        "uid": "storytime-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": true,
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "storytime-prometheus"
          },
          "refId": "A",
          "expr": "sum by (pipeline_status) (rate(pipeline_run_duration_seconds_count[5m]))",
          "legendFormat": "{{pipeline_status}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Mean run duration (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "storytime-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "storytime-prometheus"
          },
          "refId": "A",
          "expr": "sum(rate(pipeline_run_duration_seconds_sum[5m])) / sum(rate(pipeline_run_duration_seconds_count[5m]))",
          "legendFormat": "Mean run duration (5m)",
          "instant": true
        }
      ]
    }
  ]
}
