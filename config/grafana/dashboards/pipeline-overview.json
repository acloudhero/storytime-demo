{
  "uid": "storytime-pipeline-overview",
  "title": "StoryTime \u2014 Pipeline Overview",
  "description": "At-a-glance counters for the StoryTime pipeline, from the Phase 5 metric set. Counters are process-lifetime totals as exposed by Prometheus.",
  "tags": [
    "storytime",
    "phase6a",
    "observability"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "graphTooltip": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "refresh": "10s",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "hide": true,
        "name": "Annotations & Alerts",
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)"
      }
    ]
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pipeline runs",
      "datasource": {
        "type": "prometheus",
        "uid": "storytime-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "storytime-prometheus"
          },
          "refId": "A",
          "expr": "sum(pipeline_runs_total)",
          "legendFormat": "Pipeline runs",
          "instant": true
        }
      ]
    },
