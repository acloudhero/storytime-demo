# StoryTime local environment template.
# Copy to .env and adjust. .env is git-ignored.
#
# Phase 2 scaffold: these are read with safe defaults. No value here is a
# secret; StoryTime makes no authenticated API calls (local-first constraint).
# Phase 7A blue/green Option A: this file is also the template a per-slot env
# file is based on — see config/deploy/blue.env and config/deploy/green.env.

# Root directory for per-run working directories and the SQLite state DB.
# Phase 7A: if STORYTIME_DEPLOYMENT_SLOT is set and this is left unset, the
# state root defaults to runs/<slot> so blue and green never share a DB.
# Setting this explicitly overrides the slot-scoped default.
#STORYTIME_RUNS_DIR=runs

# Directory for published RSS feed and audio.
# Phase 7A: defaults to feed/<slot> when a slot is set and this is left unset.
#STORYTIME_FEED_DIR=feed

# Telemetry adapter selection: "noop" (default) or "otel".
# ARCH-LOCK: Telemetry is opt-in. Functional behaviour must never depend on it.
STORYTIME_TELEMETRY=noop

# OTLP/HTTP endpoint for the local OpenTelemetry Collector (used only when
# STORYTIME_TELEMETRY=otel). The collector runs via docker-compose.
STORYTIME_OTLP_ENDPOINT=http://127.0.0.1:4318

# Local HTTP serving. The host is validated; only loopback is permitted.
# ARCH-LOCK: HTTP bind safety — 0.0.0.0 is rejected (Architecture Baseline §15).
STORYTIME_HTTP_HOST=127.0.0.1
STORYTIME_HTTP_PORT=8000

# --- Phase 7A: blue/green Option A deployment identity ----------------------
# These are telemetry-resource attributes and (for the slot) a state-root
# selector. They are NOT secrets and carry no credentials.
#
# Deployment environment: a free-form label (local / demo / staging / ...).
# Becomes the OTel resource attribute deployment.environment.
STORYTIME_ENVIRONMENT=local
#
# Deployment slot: empty (no slot) by default, or a short lowercase identifier
# such as "blue" or "green". Must match [a-z0-9][a-z0-9._-]* — it is used as a
# filesystem path segment, so slashes and traversal are rejected. When set it
# becomes the OTel resource attribute deployment.slot AND scopes the default
# state/feed roots to runs/<slot> and feed/<slot>.
#STORYTIME_DEPLOYMENT_SLOT=

# --- Phase 7C.1: telemetry identity + optional containerization -------------
# service.instance.id is NOT configured here. It is derived automatically from
# the deployment slot (storytime-<slot>, e.g. storytime-blue) so it is stable
# and identical whether StoryTime runs bare-metal or in a container. There is
# deliberately no env knob for it — a knob could be pointed at an unstable
# container ID. See the Phase 7C / 7C.1 Resource Identity Contract.
#
# Optional containerized blue/green is available via docker-compose.app.yml.
# It is OPTIONAL: bare-metal (this file + uv run storytime ...) is the default.
# No secrets belong in this file or in any image. Any future runtime-injected
# secrets (e.g. Phase 8 vendor credentials) go in a git-ignored *.local.env /
# *.secret.env file and are never committed. See docs/deployment-containerized.md.

# --- Phase 8C: optional vendor telemetry export -----------------------------
# Vendor export (Dynatrace / New Relic) is DISABLED BY DEFAULT and is NOT
# configured in this file. Vendor endpoints and tokens are secrets, so they
# live in a separate git-ignored *.secret.env file, never here and never in
# .env. To opt in: copy config/vendor.secret.env.example to
# config/vendor.secret.env, fill in your values, and bring the stack up with
# exactly one vendor override file (docker compose -f
# docker-compose.observability.yml -f docker-compose.vendor.dynatrace.yml up -d,
# or -f docker-compose.vendor.newrelic.yml for New Relic). The two overrides
# are mutually exclusive. See docs/vendor-export-profiles.md.
